#!/bin/sh
#------------------------------------------------------------------------------
#
# laplacianSolver: 对所有时间刻逐层求解 x/y/z 三个方向的 Laplacian 方程
#
#   读取 filepath 下每个纯数字/小数时间梯度目录，
#   复制相应网格和边界条件，按方向（Tx/Ty/Tz）分别求解，
#   将结果（T）写回各时间目录下（Tx/Ty/Tz）。
#
# 控制:
#   solveX / solveY / solveZ = 1（开启）或 0（关闭）
#   endTime 从 system/controlDict 自动读取
#
#------------------------------------------------------------------------------

# ============== 需要求解的算例目录 ==============
filepath="../Re1000Std1.00AoA10Phi0.00"
# ========= 求解方向开关（1=开启，0=关闭）=========
solveX=1
solveY=1
solveZ=0
# =============== 时间刻数量统计 =================
counti=0
# ============ 读取控制文件中的endTime ===========
solverend=$(sed -n 's/^endTime[[:space:]]*\([0-9][0-9]*\(\.[0-9][0-9]*\)\?\).*/\1/p' system/controlDict)
echo "==========================================================================================="
echo "solver end time: $solverend"
# ============ 循环求解算例中所有时间刻 ===========
for folderpath in "$filepath"/*/
# for folderpath in $filepath/100 # 只计算单个时间刻
do
    # 去掉末尾的 /，提取纯文件夹名
    folder="${folderpath%/}"
    foldername="${folder##*/}"
    # 跳过包含非法字符的文件夹名（只允许数字和小数点）
    case "$foldername" in
        0)         continue ;;   # 跳过 0 文件夹
        *[!0-9.]*) continue ;;   # 含非数字、非小数点字符则跳过
        *..*)      continue ;;   # 含多个连续小数点则跳过
        .*|*.)     continue ;;   # 以点开头或结尾则跳过
    esac
    counti=$((counti + 1))
    echo "==========================================================================================="
    meshpath=$filepath/constant/polyMesh
    pointspath=$folderpath/polyMesh/points
    cp -f $filepath/system/decomposeParDict system/
    echo "Laplacian solver begin for $folderpath"
    if [ "$solveX" -eq 1 ]; then
        echo "solver for x dimension --------------------------------------------------------------------"
        ./Allclean
        mkdir -p 0/
        cp -f 0.orig/Tx 0/T
        cp -r -f $meshpath constant/
        cp -f $pointspath constant/polyMesh/
        ./Allrun
        cp -f $solverend/T $folderpath/Tx
    fi
    if [ "$solveY" -eq 1 ]; then
        echo "solver for y dimension --------------------------------------------------------------------"
        ./Allclean
        mkdir -p 0/
        cp -f 0.orig/Ty 0/T
        cp -r -f $meshpath constant/
        cp -f $pointspath constant/polyMesh/
        ./Allrun
        cp -f $solverend/T $folderpath/Ty
    fi
    if [ "$solveZ" -eq 1 ]; then
        echo "solver for z dimension --------------------------------------------------------------------"
        ./Allclean
        mkdir -p 0/
        cp -f 0.orig/Tz 0/T
        cp -r -f $meshpath constant/
        cp -f $pointspath constant/polyMesh/
        ./Allrun
        cp -f $solverend/T $folderpath/Tz
    fi
done

echo "==========================================================================================="
echo "Total folders processed: $counti"
echo "==========================================================================================="

#------------------------------------------------------------------------------